{
  "name": "browsight",
  "version": "0.0.0",
  "type": "module",
  "description": "A universal, permissioned read-and-act tool that exposes your real, authenticated Chrome to any MCP client.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/anexinwilson/browsight.git"
  },
  "keywords": ["mcp", "ai", "llm", "browser", "automation"],
  "bin": {
    "browsight": "./scripts/setup.ts"
  },
  "files": ["server/dist", "extension/dist", "shared/dist", "scripts"],
  "engines": {
    "node": ">=24"
  },
  "workspaces": ["shared", "server", "extension", "scripts"],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "lint": "biome check .",
    "format": "biome format --write .",
    "test": "node --test \"**/*.test.ts\"",
    "setup": "node scripts/setup.ts",
    "doctor": "node scripts/setup.ts doctor",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^24.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.11",
    "tsdown": "^0.22.3",
    "typescript": "^5.7.0"
  },
  "lint-staged": {
    "*.{ts,js,json,md}": "biome check --write"
  },
  "overrides": {
    "fast-uri": "^4.0.1"
  }
}

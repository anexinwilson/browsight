{
  "name": "browsight",
  "version": "0.1.4",
  "type": "module",
  "description": "A universal, permissioned read-and-act tool that exposes your real, authenticated Chrome to any MCP client.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/anexinwilson/browsight.git"
  },
  "keywords": ["mcp", "ai", "llm", "browser", "automation"],
  "bin": {
    "browsight": "./scripts/dist/setup.mjs"
  },
  "files": ["server/dist", "extension/dist", "shared/dist", "scripts/dist"],
  "engines": {
    "node": ">=24"
  },
  "workspaces": ["shared", "server", "extension", "scripts"],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "lint": "biome check .",
    "format": "biome format --write .",
    "test": "node --test \"**/*.test.ts\"",
    "setup": "node scripts/setup.ts",
    "doctor": "node scripts/setup.ts doctor",
    "prepare": "husky",
    "prepublishOnly": "npm run build",
    "postinstall": "node -e \"console.log('\\n\\x1b[36m=========================================\\n\\x1b[32m ✓ browsight installed successfully!\\n\\x1b[0m\\n To finish configuration and load the\\n Chrome extension, please run:\\n\\n   \\x1b[1m\\x1b[33mnpx browsight setup\\x1b[0m\\n\\x1b[36m=========================================\\n')\""
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/jsdom": "^28.0.3",
    "@types/node": "^24.0.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^15.2.11",
    "sharp": "^0.35.2",
    "tsdown": "^0.22.3",
    "typescript": "^5.7.0"
  },
  "lint-staged": {
    "*.{ts,js,json,md}": "biome check --write"
  },
  "overrides": {
    "fast-uri": "^4.0.1"
  },
  "dependencies": {
    "browsight": "^0.1.2"
  }
}
